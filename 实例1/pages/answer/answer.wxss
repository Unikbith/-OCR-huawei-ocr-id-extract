/* pages/anotherPage/anotherPage.wxss */
.container {
    padding: 20px;
  }
  
  .title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 20px;
    color: #333;
  }
  
  .result-list {
    background-color: #f9f9f9;
    border-radius: 10px;
    padding: 15px;
  }
  
  .result-item {
    display: flex;
    margin-bottom: 15px;
    font-size: 16px;
  }
  
  .label {
    font-weight: bold;
    color: #666;
    min-width: 80px;
  }
  
  .value {
    color: #333;
    flex: 1;
    white-space: pre-line; /* 保留换行符 */
  }