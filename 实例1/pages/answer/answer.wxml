<view class="container">
  <view class="title">处理结果：</view>
  <view class="result-list">
    <block wx:for="{{displayResult}}" wx:key="label">
      <view class="result-item">
        <text class="label">{{item.label}}：</text>
        <text class="value">{{item.value}}</text>
      </view>
    </block>
  </view>
</view>